{
  "name": "svelte-grab",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "default": "./dist/primitives.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "svelte-kit sync && svelte-package -i src/lib",
    "prepublishOnly": "bun run build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "dev": "svelte-package -w",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "happy-dom": "^*",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
