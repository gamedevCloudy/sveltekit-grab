{
  "name": "sv-grab",
  "version": "0.1.10",
  "license": "MIT",
  "description": "Select Svelte component context directly from your website. Hover any element → press ⌘C/Ctrl+C to instantly copy component name, source file, and HTML. Makes coding agents like Cursor, Claude, Copilot 3× faster and more accurate.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "default": "./dist/primitives.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "logo": "./assets/svelte-grab.webp",
  "files": [
    "dist",
    "assets/svelte-grab.webp"
  ],
  "scripts": {
    "build": "svelte-kit sync && svelte-package -i src/lib",
    "prepublishOnly": "bun run build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "dev": "svelte-package -w",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "peerDependencies": {
    "svelte": ">=5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gamedevCloudy/svelte-grab.git"
  },
  "keywords": [
    "svelte",
    "sveltekit",
    "svelte-devtools",
    "component-inspector",
    "dev-tool",
    "productivity",
    "clipboard",
    "coding-agent"
  ],
  "author": "gamedevCloudy",
  "homepage": "https://github.com/gamedevCloudy/svelte-grab#readme",
  "bugs": {
    "url": "https://github.com/gamedevCloudy/svelte-grab/issues"
  },
  "sideEffects": false,
  "devDependencies": {
    "happy-dom": "^*",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/package": "^2.3.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
